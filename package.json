{
  "name": "uplift-demo",
  "version": "1.0.0",
  "private": true,
  "description": "Uplift Workforce Management Platform - Demo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "cd apps/api && npm run dev",
    "dev:portal": "cd apps/portal && npm run dev",
    "dev:mobile": "cd apps/mobile && npm start",
    "dev:ops": "cd apps/ops && npm run dev",
    "build:portal": "cd apps/portal && npm run build",
    "start:api": "node src/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dazeavedo/uplift-demo.git"
  },
