{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api-dev.uplifthq.co.uk/api",
        "EXPO_PUBLIC_ENVIRONMENT": "development"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api-dev.uplifthq.co.uk/api",
        "EXPO_PUBLIC_ENVIRONMENT": "preview"
      }
    },
    "staging": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api-staging.uplifthq.co.uk/api",
        "EXPO_PUBLIC_ENVIRONMENT": "staging"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "distribution": "store",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://uplift-demo-production.up.railway.app/api",
        "EXPO_PUBLIC_DEMO_MODE": "true",
        "EXPO_PUBLIC_ENVIRONMENT": "production"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "5KBTBV64JE",
        "ascAppId": "6758172662"
      },
      "android": {
        "track": "internal"
      }
    }
  }
}
