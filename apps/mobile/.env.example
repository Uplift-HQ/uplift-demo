# ============================================================
# UPLIFT MOBILE APP ENVIRONMENT VARIABLES
# Copy to .env and fill in values for local development
# For production builds, set these in EAS Build secrets
# ============================================================

# API URL - The backend API endpoint
# Development: http://localhost:3000/api (default if not set)
# Staging: https://api-staging.uplifthq.co.uk/api
# Production: https://api.uplifthq.co.uk/api
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Enable demo mode (shows demo data, skips auth)
# Set to "true" for web demos on the marketing site
EXPO_PUBLIC_DEMO_MODE=false
