{
  "name": "uplift-platform",
  "version": "1.0.0",
  "description": "Uplift Workforce Intelligence Platform - Complete Solution",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "dev:portal": "cd portal && npm run dev",
    "dev:ops": "cd ops-portal && npm run dev",
    "dev:mobile": "cd mobile && npm start",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:portal\" \"npm run dev:ops\"",
    "build": "npm run build:portal && npm run build:ops",
    "build:portal": "cd portal && npm run build",
    "build:ops": "cd ops-portal && npm run build",
    "build:mobile:ios": "cd mobile && eas build --platform ios",
    "build:mobile:android": "cd mobile && eas build --platform android",
    "db:init": "psql $DATABASE_URL -f database/schema.sql",
    "db:seed": "node --experimental-modules database/seed.js",
    "db:migrate": "node scripts/migrate.js migrate",
    "db:migrate:create": "node scripts/migrate.js create",
    "db:rollback": "node scripts/migrate.js rollback",
    "db:status": "node scripts/migrate.js status",
    "db:reset": "npm run db:rollback && npm run db:migrate && npm run db:seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "./scripts/run-e2e-tests.sh",
    "test:e2e:api": "vitest run tests/e2e/api.e2e.test.js",
    "test:e2e:portal": "playwright test tests/e2e/portal.e2e.test.ts",
    "test:e2e:mobile:ios": "cd mobile && detox test --configuration ios.sim.debug",
    "test:e2e:mobile:android": "cd mobile && detox test --configuration android.emu.debug",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix",
    "lint:portal": "cd portal && npm run lint",
    "lint:mobile": "cd mobile && npm run lint",
    "lint:all": "npm run lint && npm run lint:portal && npm run lint:mobile",
    "format": "prettier --write 'src/**/*.js'",
    "format:check": "prettier --check 'src/**/*.js'",
    "typecheck": "cd mobile && npm run typecheck",
    "docker:build": "docker build -t uplift-api .",
    "docker:run": "docker run -p 3000:3000 --env-file .env uplift-api",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "deploy:staging": "kubectl apply -f k8s/ -n uplift-staging",
    "deploy:production": "kubectl apply -f k8s/ -n uplift-production",
    "setup": "npm install && cd portal && npm install && cd ../ops-portal && npm install && cd ../mobile && npm install",
    "clean": "rm -rf node_modules portal/node_modules ops-portal/node_modules mobile/node_modules",
    "validate:i18n": "node scripts/validate-i18n.js",
    "generate:api-docs": "npx @redocly/cli build-docs docs/openapi.yaml -o docs/api/index.html"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.978.0",
    "@aws-sdk/s3-request-presigner": "^3.978.0",
    "@sentry/node": "^10.37.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.67.2",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "multer-s3": "^3.0.1",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
    "passport-azure-ad": "^4.3.5",
    "passport-google-oauth20": "^2.0.0",
    "passport-saml": "^3.2.4",
    "pdfkit": "^0.17.2",
    "pg": "^8.11.3",
    "pino": "^8.21.0",
    "pino-http": "^9.0.0",
    "pino-pretty": "^10.3.1",
    "postmark": "^4.0.5",
    "puppeteer": "^24.36.1",
    "qrcode": "^1.5.3",
    "redis": "^4.6.12",
    "socket.io": "^4.7.4",
    "stripe": "^14.12.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.2.0",
    "eslint": "^8.56.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.2.0",
    "supertest": "^6.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
