# ============================================================
# UPLIFT API ENVIRONMENT VARIABLES
# Copy to .env and fill in values for local development
# NEVER commit .env files to version control
# ============================================================

# -------------------- CORE (Required) --------------------
NODE_ENV=development
PORT=3000

# -------------------- DATABASE (Required) --------------------
# Supabase PostgreSQL connection string
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# -------------------- REDIS (Optional) --------------------
# Upstash Redis URL - used for rate limiting, job queue, caching
# If not set, falls back to in-memory storage (not suitable for production)
REDIS_URL=redis://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:6379

# -------------------- AUTHENTICATION (Required) --------------------
# Generate with: openssl rand -base64 64
# MUST be at least 32 characters
JWT_SECRET=your-super-secret-jwt-key-change-this-must-be-32-chars-min
OPS_JWT_SECRET=your-ops-jwt-secret-for-backoffice-portal
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

# -------------------- CORS & URLS (Required) --------------------
API_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000
APP_URL=http://localhost:5173
PORTAL_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8081

# -------------------- STRIPE BILLING --------------------
# Use test keys for development (sk_test_xxx)
# Get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
STRIPE_PRICE_STARTER=price_starter_id
STRIPE_PRICE_PROFESSIONAL=price_professional_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_id

# -------------------- EMAIL --------------------
# Option 1: Postmark (recommended)
POSTMARK_SERVER_TOKEN=YOUR_POSTMARK_SERVER_TOKEN

# Option 2: SendGrid (legacy)
# SENDGRID_API_KEY=SG.YOUR_SENDGRID_API_KEY

# Email addresses
EMAIL_FROM=noreply@uplift.hr
EMAIL_REPLY_TO=support@uplift.hr

# -------------------- FILE STORAGE --------------------
# Option 1: AWS S3 / S3-compatible (Supabase Storage, MinIO)
S3_BUCKET=uplift-uploads
S3_REGION=us-east-1
S3_ENDPOINT=https://YOUR_PROJECT.supabase.co/storage/v1/s3
S3_CDN_URL=https://YOUR_PROJECT.supabase.co/storage/v1/object/public
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Option 2: Local file storage (development only)
UPLOAD_DIR=/tmp/uploads

# -------------------- ERROR TRACKING --------------------
# Sentry DSN for error monitoring
# Get from https://sentry.io/
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# -------------------- MONITORING & ALERTS --------------------
# Slack webhook for alerts
SLACK_ALERT_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_EMAIL=ops@uplift.hr
APP_NAME=Uplift

# -------------------- TRANSLATION SERVICES --------------------
# Option 1: Google Translate API
GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key

# Option 2: DeepL API
# DEEPL_API_KEY=your-deepl-api-key
# DEEPL_API_URL=https://api-free.deepl.com/v2/translate

# Option 3: LibreTranslate (self-hosted)
# LIBRETRANSLATE_URL=http://localhost:5000
# LIBRETRANSLATE_API_KEY=your-libre-api-key

# -------------------- INTEGRATIONS --------------------
# OAuth2 integrations - get credentials from each provider's developer console

# Google Workspace (SSO + Directory sync)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Slack (Notifications + Messaging)
# https://api.slack.com/apps
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret

# Microsoft 365 / Teams
# https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Xero (Payroll)
# https://developer.xero.com/app/manage
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret

# QuickBooks (Accounting)
# https://developer.intuit.com/app/developer/dashboard
QUICKBOOKS_CLIENT_ID=your-quickbooks-client-id
QUICKBOOKS_CLIENT_SECRET=your-quickbooks-client-secret

# ADP (Payroll/HR)
# https://developers.adp.com/
ADP_CLIENT_ID=your-adp-client-id
ADP_CLIENT_SECRET=your-adp-client-secret

# -------------------- PAYROLL PROVIDERS --------------------
# PayRun.io (UK Payroll & RTI) - HMRC-recognised
# https://developer.payrun.io
PAYRUN_CONSUMER_KEY=your-payrun-consumer-key
PAYRUN_CONSUMER_SECRET=your-payrun-consumer-secret

# Thomson Reuters ONESOURCE (Multi-country payroll)
# https://tax.thomsonreuters.com/onesource/
ONESOURCE_API_KEY=your-onesource-api-key
ONESOURCE_API_URL=https://api.onesource.thomsonreuters.com

# -------------------- OPEN BANKING --------------------
# TrueLayer (Corporate Cards / Expense Bank Feeds)
# https://console.truelayer.com/
TRUELAYER_CLIENT_ID=your-truelayer-client-id
TRUELAYER_CLIENT_SECRET=your-truelayer-client-secret
TRUELAYER_SANDBOX=true
# Set to false for production

# -------------------- MOBILE PUSH NOTIFICATIONS --------------------
# Expo Push Notifications (for React Native mobile app)
# https://expo.dev/accounts/[account]/settings/access-tokens
EXPO_ACCESS_TOKEN=your-expo-access-token
EXPO_PROJECT_ID=your-expo-project-id

# Firebase Cloud Messaging (alternative to Expo)
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com

# -------------------- OCR / RECEIPT SCANNING --------------------
# Tesseract.js language data path (optional, uses CDN by default)
# TESSERACT_LANG_PATH=/path/to/tessdata
# Default OCR language
OCR_DEFAULT_LANGUAGE=eng

# -------------------- MOMENTUM SCORING --------------------
# Calculation frequency (cron expression)
MOMENTUM_CALC_SCHEDULE=0 2 * * *
# Weight configuration (must sum to 1.0)
MOMENTUM_WEIGHT_ATTENDANCE=0.20
MOMENTUM_WEIGHT_PUNCTUALITY=0.15
MOMENTUM_WEIGHT_SHIFT_COMPLETION=0.15
MOMENTUM_WEIGHT_SKILLS_GROWTH=0.15
MOMENTUM_WEIGHT_RECOGNITION=0.15
MOMENTUM_WEIGHT_ENGAGEMENT=0.20

# -------------------- FEATURE FLAGS --------------------
ENABLE_AI_SCHEDULING=true
ENABLE_GAMIFICATION=true
ENABLE_INTERNAL_MOBILITY=true
ENABLE_MOMENTUM_SCORES=true
ENABLE_OCR_RECEIPTS=true
ENABLE_OPEN_BANKING=true

# -------------------- RATE LIMITING --------------------
# Requests per window (default: 100 per 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# Auth endpoints (stricter limits)
AUTH_RATE_LIMIT_WINDOW_MS=300000
AUTH_RATE_LIMIT_MAX_REQUESTS=10

# -------------------- LOGGING --------------------
# debug, info, warn, error
LOG_LEVEL=debug

# -------------------- SECURITY --------------------
# Session and CSRF (if using session-based auth)
SESSION_SECRET=your-session-secret-change-this
# Allowed upload file types
ALLOWED_UPLOAD_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf
MAX_UPLOAD_SIZE_MB=10
