# NL-18: Environment variables for Uplift Portal
# Copy this file to .env.local and fill in the values

# API URL - Backend server endpoint
VITE_API_URL=http://localhost:3000

# Demo mode - enables demo login cards and fallback data when API unavailable
# Set to true for demo/production deployments with persona login cards
# Set to false for development against a real backend
VITE_DEMO_MODE=true

# Anthropic API key for AI chatbot (demo only)
# Create a restricted key with spend limits at https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=your_api_key_here
